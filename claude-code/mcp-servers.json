{
  "$schema": "MCP servers config template. Replace <PLACEHOLDER> values with real credentials. Servers provided by n24q02m-plugins are NOT listed here — they are managed via the plugin marketplace.",
  "mcpServers": {
    "sequential-thinking": {
      "command": "bun",
      "args": ["x", "@modelcontextprotocol/server-sequential-thinking@latest"]
    },
    "stitch": {
      "type": "http",
      "url": "https://stitch.googleapis.com/mcp",
      "headers": {
        "X-Goog-Api-Key": "<STITCH_API_KEY>"
      }
    },
    "grafana": {
      "command": "uvx",
      "args": ["mcp-grafana"],
      "env": {
        "GRAFANA_URL": "<GRAFANA_URL>",
        "GRAFANA_SERVICE_ACCOUNT_TOKEN": "<GRAFANA_TOKEN>"
      }
    }
  }
}
