{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "50"
  },
  "permissions": {
    "defaultMode": "bypassPermissions"
  },
  "enabledPlugins": {
    "security-guidance@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "feature-dev@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true,
    "pr-review-toolkit@claude-plugins-official": true,
    "gopls-lsp@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "rust-analyzer-lsp@claude-plugins-official": true,
    "playwright@claude-plugins-official": true,
    "chrome-devtools-mcp@claude-plugins-official": true,
    "wet-mcp@n24q02m-plugins": true,
    "mnemo-mcp@n24q02m-plugins": true,
    "better-notion-mcp@n24q02m-plugins": true,
    "better-code-review-graph@n24q02m-plugins": true,
    "better-email-mcp@n24q02m-plugins": true,
    "better-godot-mcp@n24q02m-plugins": true,
    "better-telegram-mcp@n24q02m-plugins": true
  },
  "extraKnownMarketplaces": {
    "cc-marketplace": {
      "source": {
        "source": "github",
        "repo": "kenryu42/cc-marketplace"
      }
    },
    "n24q02m-plugins": {
      "source": {
        "source": "github",
        "repo": "n24q02m/claude-plugins"
      }
    }
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "command": "python3 -c \"import json,sys,os,datetime; d=json.load(sys.stdin); f=open(os.path.expanduser('~/.claude/skill-usage.log'),'a'); f.write(f\\\"{datetime.datetime.now().isoformat()} {d.get('tool_input',{}).get('skill','unknown')}\\\\n\\\"); f.close()\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python3 -c \"import json,sys,os,datetime; d=json.load(sys.stdin); tool=d.get('tool_name',''); result=str(d.get('tool_result',{}).get('content',''))[:200]; log=os.path.expanduser('~/.claude/instinct.log'); f=open(log,'a'); f.write(f\\\"{datetime.datetime.now().isoformat()} {tool} {result[:100]}\\\\n\\\"); f.close()\" 2>/dev/null"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python3 -c \"import json,sys,os,urllib.request; d=json.load(sys.stdin); token=os.environ.get('VC_SECRETARY_BOT_TOKEN',''); chat=os.environ.get('VC_OWNER_CHAT_ID','7305908576'); msg=f'Claude Code session ended: {d.get(\\\"session_id\\\",\\\"unknown\\\")[:8]}'; token and urllib.request.urlopen(urllib.request.Request(f'https://api.telegram.org/bot{token}/sendMessage',data=json.dumps({\\\"chat_id\\\":chat,\\\"text\\\":msg}).encode(),headers={\\\"Content-Type\\\":\\\"application/json\\\"}))\" 2>/dev/null"
          }
        ]
      }
    ]
  },
  "effortLevel": "high",
  "skipDangerousModePermissionPrompt": true
}
